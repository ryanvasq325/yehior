APP_ENV=production
APP_DEBUG=true
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_NAME=development_db
DB_USER=
DB_PASSWORD=
TZ=America/Porto_Velho

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1
REDIS_PREFIX=SESS:
REDIS_TIMEOUT=2.5
REDIS_READ_TIMEOUT=2.5
REDIS_PERSISTENT=1

OPCACHE_VALIDATE_TIMESTAMPS=1

# Xdebug desligado por padrão - use "debug" quando precisar de breakpoints
XDEBUG_MODE=off

APP_DOMAIN=localhost